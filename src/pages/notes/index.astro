---
import Layout from '../../layouts/Layout.astro';

const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });

const notes = Object.entries(noteFiles)
  .filter(([path]) => !path.includes('二掌柜'))
  .map(([path, module]: [string, any]) => {
    const parts = path.split('/');
    const category = parts[parts.length - 2] || '其他';
    const filename = parts.pop()?.replace('.md', '') || 'Untitled';
    
    // 去掉分类名中的 emoji 前缀（如 "📰 山水邸报" → "山水邸报"）
    const categoryClean = category.replace(/^[^\u4e00-\u9fff]+/, '').trim() || category;
    const slug = `${category}/${filename}`;
    
    // 格式化日期
    let dateStr = module.frontmatter?.date || '';
    if (dateStr) {
      try {
        const d = new Date(dateStr);
        if (!isNaN(d.getTime())) {
          const weekdays = ['日', '一', '二', '三', '四', '五', '六'];
          dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')} 星期${weekdays[d.getDay()]}`;
        }
      } catch {}
    }
    
    // 改进摘要提取
    let excerpt = '';
    const raw = module.raw || '';
    if (raw) {
      // 跳过 frontmatter，取第一段有意义的文本
      const content = raw.replace(/^---[\s\S]*?---\s*/, '').trim();
      const lines = content.split('\n').filter((l: string) => l.trim() && !l.startsWith('#') && !l.startsWith('!['));
      excerpt = lines.slice(0, 2).join(' ').replace(/[#*\-_>`\[\]]/g, '').trim().slice(0, 120);
      if (excerpt.length >= 120) excerpt += '...';
    }
    
    return {
      title: module.frontmatter?.title || filename,
      date: dateStr,
      tags: module.frontmatter?.tags || [],
      excerpt,
      slug,
      category: categoryClean,
      categoryRaw: category,
    };
  })
  .sort((a: any, b: any) => (b.date > a.date ? 1 : -1));

const categories = [...new Set(notes.map((n: any) => n.category))];
const categoryIcons: Record<string, string> = {
  '山水邸报': '📰',
  '本周必读': '📖',
  '学海无涯': '📝',
  '金精铜钱': '💰',
  '夜航船': '⛵',
  '撼山拳谱': '📜',
};
---

<Layout title="笔记 - 白也">
  <section class="mb-8">
    <h1 class="text-[34px] font-bold tracking-tight mb-2">笔记</h1>
    <p class="text-[#8E8E93]">来自 Obsidian 的知识沉淀</p>
  </section>

  {notes.length === 0 ? (
    <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
      <div class="text-4xl mb-3">📭</div>
      <p class="text-[#8E8E93]">还没有笔记，正在同步中...</p>
    </div>
  ) : (
    <!-- Category filter -->
    <div class="flex gap-2 mb-6 overflow-x-auto scrollbar-hide pb-2 -mx-3 px-3 sm:mx-0 sm:px-0 sm:flex-wrap">
      <button class="category-filter px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium bg-[#4169E1] text-white transition-all whitespace-nowrap" data-category="all">
        全部
      </button>
      {categories.map((category: string) => (
        <button class="category-filter px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium bg-white text-[#3C3C43] hover:bg-[#F2F2F7] transition-all shadow-sm whitespace-nowrap" data-category={category}>
          {categoryIcons[category] || '📄'} {category}
        </button>
      ))}
    </div>

    <!-- Notes list -->
    <div class="space-y-3" id="notes-list">
      {notes.map((note: any) => (
        <a href={`/notes/${note.slug}`} class="note-card bg-white rounded-2xl p-5 block shadow-sm hover:shadow-md transition-shadow group" data-category={note.category}>
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-[#8E8E93]">{categoryIcons[note.category] || '📄'} {note.category}</span>
                {note.date && <span class="text-xs text-[#C6C6C8]">·</span>}
                {note.date && <span class="text-xs text-[#8E8E93]">{note.date}</span>}
              </div>
              <h3 class="font-semibold text-base mb-1 group-hover:text-[#4169E1] transition-colors">
                {note.title}
              </h3>
              <p class="text-sm text-[#8E8E93] line-clamp-2">{note.excerpt}</p>
              {note.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {note.tags.slice(0, 3).map((tag: string) => (
                    <span class="px-2 py-0.5 rounded-full bg-[#F2F2F7] text-[#8E8E93] text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <svg class="w-5 h-5 text-[#C6C6C8] group-hover:text-[#4169E1] transition-colors flex-shrink-0 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  )}
</Layout>

<script is:inline>
  // Category filter
  document.querySelectorAll('.category-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      
      // Update active button
      document.querySelectorAll('.category-filter').forEach(b => {
        b.classList.remove('bg-[#4169E1]', 'text-white');
        b.classList.add('bg-white', 'text-[#3C3C43]');
      });
      btn.classList.remove('bg-white', 'text-[#3C3C43]');
      btn.classList.add('bg-[#4169E1]', 'text-white');
      
      // Filter notes
      document.querySelectorAll('.note-card').forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
