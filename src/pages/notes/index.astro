---
import Layout from '../../layouts/Layout.astro';

const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });

const notes = Object.entries(noteFiles)
  .filter(([path]) => {
    if (path.includes('二掌柜')) return false;
    const filename = path.split('/').pop() || '';
    // 过滤内部文件
    if (filename === 'README.md') return false;
    if (filename.includes('归档规范')) return false;
    if (filename.includes('排版规范')) return false;
    if (filename.includes('模板')) return false;
    if (filename.startsWith('.')) return false;
    return true;
  })
  .map(([path, module]: [string, any]) => {
    const parts = path.split('/');
    const category = parts[parts.length - 2] || '其他';
    const filename = parts.pop()?.replace('.md', '') || 'Untitled';
    
    const categoryClean = category.replace(/^[^\u4e00-\u9fff]+/, '').trim() || category;
    const slug = `${category}/${filename}`;
    
    let dateStr = module.frontmatter?.date || '';
    if (dateStr) {
      try {
        const d = new Date(dateStr);
        if (!isNaN(d.getTime())) {
          const weekdays = ['日', '一', '二', '三', '四', '五', '六'];
          dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')} 星期${weekdays[d.getDay()]}`;
        }
      } catch {}
    }
    
    let excerpt = '';
    const raw = module.raw || '';
    if (raw) {
      const content = raw.replace(/^---[\s\S]*?---\s*/, '').trim();
      const lines = content.split('\n').filter((l: string) => l.trim() && !l.startsWith('#') && !l.startsWith('!['));
      excerpt = lines.slice(0, 2).join(' ').replace(/[#*\-_>`\[\]]/g, '').trim().slice(0, 120);
      if (excerpt.length >= 120) excerpt += '...';
    }
    
    return {
      title: module.frontmatter?.title || filename,
      date: dateStr,
      tags: module.frontmatter?.tags || [],
      excerpt,
      fullText: raw.replace(/^---[\s\S]*?---\s*/, '').replace(/[#*\-_>`\[\]!|]/g, '').trim().toLowerCase().slice(0, 500),
      slug,
      category: categoryClean,
      categoryRaw: category,
    };
  })
  .sort((a: any, b: any) => (b.date > a.date ? 1 : -1));

const categories = [...new Set(notes.map((n: any) => n.category))];
const allTags = [...new Set(notes.flatMap((n: any) => n.tags))].sort();
const categoryIcons: Record<string, string> = {
  '山水邸报': '📰',
  '本周必读': '📖',
  '学海无涯': '📝',
  '金精铜钱': '💰',
  '夜航船': '⛵',
  '撼山拳谱': '📜',
};
---

<Layout title="笔记 - 白也">
  <section class="mb-6">
    <h1 class="text-[34px] font-bold tracking-tight mb-2">笔记</h1>
    <p class="text-[#8E8E93]">来自 Obsidian 的知识沉淀</p>
  </section>

  {notes.length === 0 ? (
    <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
      <div class="text-4xl mb-3">📭</div>
      <p class="text-[#8E8E93]">还没有笔记，正在同步中...</p>
    </div>
  ) : (
    <!-- Search -->
    <div class="mb-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#8E8E93]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="搜索笔记标题、内容..."
          class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-[#F2F2F7] text-sm outline-none focus:ring-2 focus:ring-[#4169E1]/20 transition-shadow"
        />
      </div>
    </div>

    <!-- Category filter -->
    <div class="flex gap-1.5 mb-3 overflow-x-auto scrollbar-hide pb-1 -mx-3 px-3 sm:mx-0 sm:px-0 sm:flex-wrap">
      <button class="category-filter px-3 py-1.5 rounded-lg text-xs font-medium bg-[#F2F2F7] text-[#636366] active:bg-[#4169E1] active:text-white transition-colors whitespace-nowrap" data-category="all">
        全部
      </button>
      {categories.map((category: string) => (
        <button class="category-filter px-3 py-1.5 rounded-lg text-xs font-medium bg-[#F2F2F7] text-[#636366] active:bg-[#4169E1] active:text-white transition-colors whitespace-nowrap" data-category={category}>
          {categoryIcons[category] || '📄'} {category}
        </button>
      ))}
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex gap-1 mb-5 overflow-x-auto scrollbar-hide pb-1 -mx-3 px-3 sm:mx-0 sm:px-0 sm:flex-wrap">
        {allTags.slice(0, 15).map((tag: string) => (
          <button class="tag-filter px-2 py-0.5 rounded-md bg-[#F2F2F7] text-[#8E8E93] text-xs active:bg-[#4169E1] active:text-white transition-colors whitespace-nowrap" data-tag={tag}>
            #{tag}
          </button>
        ))}
      </div>
    )}

    <!-- Notes list -->
    <div class="space-y-3" id="notes-list">
      {notes.map((note: any) => (
        <a
          href={`/notes/${note.slug}`}
          class="note-card bg-white rounded-2xl p-5 block shadow-sm hover:shadow-md transition-shadow group"
          data-category={note.category}
          data-tags={note.tags.join(',')}
          data-title={note.title.toLowerCase()}
          data-excerpt={note.excerpt.toLowerCase()}
          data-fulltext={note.fullText}
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-[#8E8E93]">{categoryIcons[note.category] || '📄'} {note.category}</span>
                {note.date && <span class="text-xs text-[#C6C6C8]">·</span>}
                {note.date && <span class="text-xs text-[#8E8E93]">{note.date}</span>}
              </div>
              <h3 class="font-semibold text-base mb-1 group-hover:text-[#4169E1] transition-colors note-title">
                {note.title}
              </h3>
              <p class="text-sm text-[#8E8E93] line-clamp-2 note-excerpt">{note.excerpt}</p>
              {note.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {note.tags.slice(0, 3).map((tag: string) => (
                    <span class="note-tag px-2 py-0.5 rounded-full bg-[#F2F2F7] text-[#8E8E93] text-xs cursor-pointer hover:bg-[#E8E8ED] transition-colors" data-tag={tag}>
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <svg class="w-5 h-5 text-[#C6C6C8] group-hover:text-[#4169E1] transition-colors flex-shrink-0 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state for search/filter -->
    <div id="no-results" class="hidden bg-white rounded-2xl p-8 text-center shadow-sm">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-[#8E8E93]">没有找到匹配的笔记</p>
    </div>
  )}
</Layout>

<script is:inline>
  let activeCategory = 'all';
  let activeTag = '';

  function filterNotes() {
    const searchVal = document.getElementById('search-input')?.value.toLowerCase() || '';
    let visibleCount = 0;

    document.querySelectorAll('.note-card').forEach(card => {
      const matchCategory = activeCategory === 'all' || card.dataset.category === activeCategory;
      const matchTag = !activeTag || (card.dataset.tags || '').split(',').includes(activeTag);
      const matchSearch = !searchVal ||
        (card.dataset.title || '').includes(searchVal) ||
        (card.dataset.excerpt || '').includes(searchVal) ||
        (card.dataset.tags || '').includes(searchVal) ||
        (card.dataset.fulltext || '').includes(searchVal);

      if (matchCategory && matchTag && matchSearch) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    document.getElementById('no-results')?.classList.toggle('hidden', visibleCount > 0);
  }

  // Helper: set active state on filter buttons
  function setActive(btns, activeBtn) {
    btns.forEach(b => {
      b.classList.remove('bg-[#4169E1]', 'text-white');
      b.classList.add('bg-[#F2F2F7]', 'text-[#636366]');
    });
    if (activeBtn) {
      activeBtn.classList.remove('bg-[#F2F2F7]', 'text-[#636366]');
      activeBtn.classList.add('bg-[#4169E1]', 'text-white');
    }
  }

  // Category filter
  const catBtns = document.querySelectorAll('.category-filter');
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category;
      setActive(catBtns, btn);
      filterNotes();
    });
  });

  // Tag filter (top bar)
  const tagBtns = document.querySelectorAll('.tag-filter');
  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      if (activeTag === tag) {
        activeTag = '';
        setActive(tagBtns, null);
      } else {
        activeTag = tag;
        setActive(tagBtns, btn);
      }
      filterNotes();
    });
  });

  // Tag click on note card
  document.querySelectorAll('.note-tag').forEach(tag => {
    tag.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      activeTag = tag.dataset.tag;
      const matchBtn = [...tagBtns].find(b => b.dataset.tag === activeTag);
      setActive(tagBtns, matchBtn);
      filterNotes();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Search
  document.getElementById('search-input')?.addEventListener('input', filterNotes);
</script>
