---
import Layout from '../../layouts/Layout.astro';

const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });

const notes = Object.entries(noteFiles)
  .filter(([path]) => {
    if (path.includes('二掌柜')) return false;
    const filename = path.split('/').pop() || '';
    if (filename === 'README.md') return false;
    if (filename.includes('归档规范')) return false;
    if (filename.includes('排版规范')) return false;
    if (filename.includes('模板')) return false;
    if (filename.startsWith('.')) return false;
    return true;
  })
  .map(([path, module]: [string, any]) => {
    const parts = path.split('/');
    const category = parts[parts.length - 2] || '其他';
    const filename = parts.pop()?.replace('.md', '') || 'Untitled';
    
    const categoryClean = category.replace(/^[^\u4e00-\u9fff]+/, '').trim() || category;
    const slug = `${category}/${filename}`;
    
    let dateStr = module.frontmatter?.date || '';
    if (dateStr) {
      try {
        const d = new Date(dateStr);
        if (!isNaN(d.getTime())) {
          const weekdays = ['日', '一', '二', '三', '四', '五', '六'];
          dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')} 星期${weekdays[d.getDay()]}`;
        }
      } catch {}
    }
    
    let excerpt = '';
    const raw = module.raw || '';
    if (raw) {
      const content = raw.replace(/^---[\s\S]*?---\s*/, '').trim();
      const lines = content.split('\n').filter((l: string) => l.trim() && !l.startsWith('#') && !l.startsWith('!['));
      excerpt = lines.slice(0, 2).join(' ').replace(/[#*\-_>`\[\]]/g, '').trim().slice(0, 120);
      if (excerpt.length >= 120) excerpt += '...';
    }
    
    return {
      title: module.frontmatter?.title || filename,
      date: dateStr,
      tags: module.frontmatter?.tags || [],
      excerpt,
      fullText: raw.replace(/^---[\s\S]*?---\s*/, '').replace(/[#*_\->`\[\]!|]/g, '').trim().toLowerCase().slice(0, 500),
      readingTime: Math.max(1, Math.ceil(raw.replace(/^---[\s\S]*?---\s*/, '').replace(/[#*_\->`\[\]!|]/g, '').trim().length / 400)),
      slug,
      category: categoryClean,
      categoryRaw: category,
    };
  })
  .sort((a: any, b: any) => (b.date > a.date ? 1 : -1));

const categories = [...new Set(notes.map((n: any) => n.category))];
const allTags = [...new Set(notes.flatMap((n: any) => n.tags))].sort();
const categoryIcons: Record<string, string> = {
  '山水邸报': '📰',
  '本周必读': '📖',
  '学海无涯': '📝',
  '金精铜钱': '💰',
  '夜航船': '⛵',
  '撼山拳谱': '📜',
};

const categoryColors: Record<string, string> = {
  '山水邸报': 'var(--accent)',
  '夜航船': 'var(--sage)',
  '本周必读': '#7C5CFC',
  '学海无涯': '#D4A03A',
  '金精铜钱': '#D4A03A',
};
---

<Layout title="笔记 - 白也">
  <!-- Header -->
  <section class="mb-10 reveal">
    <h1 class="font-serif text-[36px] sm:text-[44px] font-bold tracking-tight mb-2" style="color: var(--text-primary);">
      笔记<span style="color: var(--accent);">.</span>
    </h1>
    <p class="text-sm" style="color: var(--text-tertiary);">来自 Obsidian 的知识沉淀，共 {notes.length} 篇</p>
  </section>

  {notes.length === 0 ? (
    <div class="card p-10 text-center reveal reveal-delay-1">
      <div class="text-4xl mb-3">📭</div>
      <p style="color: var(--text-tertiary);">还没有笔记，正在同步中...</p>
    </div>
  ) : (
    <!-- Search -->
    <div class="mb-5 reveal reveal-delay-1">
      <div class="relative">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--text-tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="搜索笔记..."
          class="w-full pl-10 pr-4 py-2.5 rounded-xl text-sm outline-none transition-all duration-200"
          style="background: var(--bg-elevated); color: var(--text-primary); border: 1px solid var(--border);"
          onfocus="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 3px var(--accent-soft)'"
          onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
        />
      </div>
    </div>

    <!-- Category filter -->
    <div class="flex gap-1.5 mb-3 overflow-x-auto scrollbar-hide pb-1 -mx-5 px-5 sm:mx-0 sm:px-0 sm:flex-wrap reveal reveal-delay-2">
      <button class="category-filter px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200 whitespace-nowrap"
              style="background: var(--bg-elevated); color: var(--text-secondary); border: 1px solid var(--border);"
              data-category="all">
        全部
      </button>
      {categories.map((category: string) => (
        <button class="category-filter px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200 whitespace-nowrap"
                style="background: var(--bg-elevated); color: var(--text-secondary); border: 1px solid var(--border);"
                data-category={category}>
          {categoryIcons[category] || '📄'} {category}
        </button>
      ))}
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex gap-1.5 mb-6 overflow-x-auto scrollbar-hide pb-1 -mx-5 px-5 sm:mx-0 sm:px-0 sm:flex-wrap reveal reveal-delay-3">
        {allTags.slice(0, 15).map((tag: string) => (
          <button class="tag-filter tag transition-all duration-200 text-[11px] py-0.5 px-2 whitespace-nowrap flex-shrink-0" data-tag={tag}>
            #{tag}
          </button>
        ))}
      </div>
    )}

    <!-- Notes list -->
    <div class="space-y-3" id="notes-list">
      {notes.map((note: any, i: number) => (
        <a
          href={`/notes/${note.slug}`}
          class="note-card card card-accent block group"
          style={`transition-delay: ${Math.min(i * 30, 200)}ms`}
          data-category={note.category}
          data-tags={note.tags.join(',')}
          data-title={note.title.toLowerCase()}
          data-excerpt={note.excerpt.toLowerCase()}
          data-fulltext={note.fullText}
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background: ${categoryColors[note.category] || 'var(--text-tertiary)'};`}></span>
                <span class="text-xs font-medium" style="color: var(--text-tertiary);">{note.category}</span>
                {note.date && <span class="text-xs" style="color: var(--border);">·</span>}
                {note.date && <span class="text-xs" style="color: var(--text-tertiary);">{note.date}</span>}
                <span class="text-xs" style="color: var(--border);">·</span>
                <span class="text-xs" style="color: var(--text-tertiary);">约 {note.readingTime} 分钟</span>
              </div>
              <h3 class="font-medium text-[15px] mb-1 group-hover:text-[var(--accent)] transition-colors duration-200" style="color: var(--text-primary);">
                {note.title}
              </h3>
              <p class="text-sm line-clamp-2 note-excerpt" style="color: var(--text-secondary);">{note.excerpt}</p>
              {note.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-2.5">
                  {note.tags.slice(0, 3).map((tag: string) => (
                    <span class="note-tag tag text-[11px] py-0 px-2 whitespace-nowrap" data-tag={tag}>
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <svg class="w-4 h-4 flex-shrink-0 mt-2 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-[var(--accent)]" style="color: var(--border);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden card p-10 text-center">
      <div class="text-4xl mb-3">🔍</div>
      <p style="color: var(--text-tertiary);">没有找到匹配的笔记</p>
    </div>
  )}
</Layout>

<script is:inline>
  let activeCategory = 'all';
  let activeTag = '';

  function filterNotes() {
    const searchVal = document.getElementById('search-input')?.value.toLowerCase() || '';
    let visibleCount = 0;

    document.querySelectorAll('.note-card').forEach(card => {
      const matchCategory = activeCategory === 'all' || card.dataset.category === activeCategory;
      const matchTag = !activeTag || (card.dataset.tags || '').split(',').includes(activeTag);
      const matchSearch = !searchVal ||
        (card.dataset.title || '').includes(searchVal) ||
        (card.dataset.excerpt || '').includes(searchVal) ||
        (card.dataset.tags || '').includes(searchVal) ||
        (card.dataset.fulltext || '').includes(searchVal);

      if (matchCategory && matchTag && matchSearch) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    document.getElementById('no-results')?.classList.toggle('hidden', visibleCount > 0);
  }

  function setActive(btns, activeBtn) {
    btns.forEach(b => {
      b.style.background = 'var(--bg-elevated)';
      b.style.color = 'var(--text-secondary)';
      b.style.borderColor = 'var(--border)';
    });
    if (activeBtn) {
      activeBtn.style.background = 'var(--accent)';
      activeBtn.style.color = '#fff';
      activeBtn.style.borderColor = 'var(--accent)';
    }
  }

  const catBtns = document.querySelectorAll('.category-filter');
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category;
      setActive(catBtns, btn);
      filterNotes();
    });
  });

  const tagBtns = document.querySelectorAll('.tag-filter');
  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      if (activeTag === tag) {
        activeTag = '';
        setActive(tagBtns, null);
      } else {
        activeTag = tag;
        setActive(tagBtns, btn);
      }
      filterNotes();
    });
  });

  document.querySelectorAll('.note-tag').forEach(tag => {
    tag.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      activeTag = tag.dataset.tag;
      const matchBtn = [...tagBtns].find(b => b.dataset.tag === activeTag);
      setActive(tagBtns, matchBtn);
      filterNotes();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  document.getElementById('search-input')?.addEventListener('input', filterNotes);
</script>
