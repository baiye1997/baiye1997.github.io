---
import Layout from '../../layouts/Layout.astro';
import { slug as githubSlug } from 'github-slugger';
import gitLastmod from '../../data/git-lastmod.ts';

const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });

function isPublicNote(path: string): boolean {
  if (path.includes('二掌柜')) return false;
  const filename = path.split('/').pop() || '';
  if (filename === 'README.md') return false;
  if (filename.includes('归档规范')) return false;
  if (filename.includes('排版规范')) return false;
  if (filename.includes('模板')) return false;
  if (filename.startsWith('.')) return false;
  return true;
}

const allNotes: Record<string, any> = {};
const notesList: any[] = [];
for (const [path, module] of Object.entries(noteFiles)) {
  if (!isPublicNote(path)) continue;
  const parts = path.split('/');
  const category = parts[parts.length - 2] || '其他';
  const filename = parts.pop()?.replace('.md', '') || 'index';
  const slug = `${category}/${filename}`;
  
  const rawHtml = await module.compiledContent?.() || '';
  // Extract path relative to src/content/notes/ for git-lastmod lookup
  const notesRelPath = 'src/content/notes/' + path.split('src/content/notes/')[1];
  const lastmod = (gitLastmod as Record<string, string>)[notesRelPath] || '';
  const noteData = {
    title: module.frontmatter?.title || filename,
    date: module.frontmatter?.date || '',
    lastmod,
    tags: module.frontmatter?.tags || [],
    category,
    content: convertWikilinks(typeof rawHtml === 'string' ? rawHtml : ''),
    slug,
  };
  allNotes[slug] = noteData;
  notesList.push(noteData);
}

notesList.sort((a: any, b: any) => (b.date > a.date ? 1 : -1));

export function getStaticPaths() {
  const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });
  const paths: { params: { slug: string } }[] = [];
  
  for (const path of Object.keys(noteFiles)) {
    if (path.includes('二掌柜')) continue;
    const filename = path.split('/').pop() || '';
    if (filename === 'README.md' || filename.includes('归档规范') || filename.includes('排版规范') || filename.includes('模板') || filename.startsWith('.')) continue;
    const parts = path.split('/');
    const category = parts[parts.length - 2] || '其他';
    const fname = parts.pop()?.replace('.md', '') || 'index';
    paths.push({ params: { slug: `${category}/${fname}` } });
  }
  
  return paths;
}

const { slug } = Astro.params;
const note = allNotes[slug || ''];

if (!note) {
  return Astro.redirect('/notes');
}

const currentIndex = notesList.findIndex((n: any) => n.slug === slug);
const prevNote = currentIndex < notesList.length - 1 ? notesList[currentIndex + 1] : null;
const nextNote = currentIndex > 0 ? notesList[currentIndex - 1] : null;

const categoryColors: Record<string, string> = {
  '山水邸报': 'var(--accent)',
  '夜航船': 'var(--sage)',
  '本周必读': '#7C5CFC',
  '学海无涯': '#D4A03A',
  '金精铜钱': '#D4A03A',
};

// Format date: "2026-04-27T00:00:00.000Z" → "2026-04-27" or "2026-04-27 18:57"
function formatDate(raw: any, includeTime = false): string {
  if (!raw) return '';
  const s = String(raw);
  // Already simple date like "2026-04-27"
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
  // ISO timestamp or Date object
  try {
    const d = new Date(s);
    if (!isNaN(d.getTime())) {
      const date = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
      if (includeTime) {
        const hours = d.getHours();
        const mins = String(d.getMinutes()).padStart(2,'0');
        return `${date} ${String(hours).padStart(2,'0')}:${mins}`;
      }
      return date;
    }
  } catch {}
  // Fallback: extract date part before any space or T
  return s.split(/[T\s]/)[0] || s;
}

// Convert Obsidian wikilinks to HTML links
// [[#heading]] → anchor links, [[path]] / [[path|display]] → note links
function convertWikilinks(html: string): string {
  if (typeof html !== 'string') return html || '';
  return html.replace(/\[\[([^\]]+)\]\]/g, (_match: string, content: string) => {
    // Heading link: [[#heading]] or [[#heading|display]]
    if (content.startsWith('#')) {
      const heading = content.slice(1).split('|')[0];
      const slug = githubSlug(heading);
      return `<a href="#${slug}">${heading}</a>`;
    }
    // Note link: [[path]] or [[path|display]]
    const [path, display] = content.split('|');
    const displayText = display?.trim() || path.split('/').pop()?.trim() || path.trim();
    const notePath = `/notes/${path.trim()}`;
    return `<a href="${notePath}">${displayText}</a>`;
  });
}
---

<Layout title={`${note.title} - 白也`}>
  <!-- Back button -->
  <a href="/notes" class="inline-flex items-center gap-1.5 text-sm mb-6 transition-colors hover:text-[var(--accent)]" style="color: var(--text-tertiary);">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
    </svg>
    返回笔记
  </a>

  <!-- Note header -->
  <article class="card mb-6 note-article">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-block w-2 h-2 rounded-full" style={`background: ${categoryColors[note.category] || 'var(--text-tertiary)'};`}></span>
      <span class="text-xs font-medium" style="color: var(--text-tertiary);">{note.category}</span>
      {note.date && <span class="text-xs" style="color: var(--border);">·</span>}
      {note.date && <span class="text-xs" style="color: var(--text-tertiary);">{formatDate(note.date)}</span>}
      {note.lastmod && (
        <span class="text-xs" style="color: var(--text-tertiary);">· 更新于 {formatDate(note.lastmod, true)}</span>
      )}
    </div>
    
    <h1 class="font-serif text-[24px] sm:text-[30px] font-bold tracking-tight mb-4 leading-tight" style="color: var(--text-primary);">{note.title}</h1>
    
    {note.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-6">
        {note.tags.map((tag: string) => (
          <span class="tag text-[11px] py-0 px-2">
            #{tag}
          </span>
        ))}
      </div>
    )}
    
    <!-- Note content -->
    <div class="note-content leading-relaxed" style="color: var(--text-primary);">
      <Fragment set:html={note.content} />
    </div>
  </article>

  <!-- Prev/Next navigation -->
  {(prevNote || nextNote) && (
    <div class="grid grid-cols-2 gap-3 mb-8">
      {prevNote ? (
        <a href={`/notes/${prevNote.slug}`} class="card group">
          <div class="text-xs mb-1" style="color: var(--text-tertiary);">← 上一篇</div>
          <div class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors line-clamp-2" style="color: var(--text-primary);">{prevNote.title}</div>
        </a>
      ) : <div />}
      {nextNote ? (
        <a href={`/notes/${nextNote.slug}`} class="card group text-right">
          <div class="text-xs mb-1" style="color: var(--text-tertiary);">下一篇 →</div>
          <div class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors line-clamp-2" style="color: var(--text-primary);">{nextNote.title}</div>
        </a>
      ) : <div />}
    </div>
  )}
</Layout>

<style is:global>
  .note-content {
    font-size: 15px;
    line-height: 1.75;
  }

  .note-content h1 {
    font-family: 'Crimson Pro', 'Noto Serif SC', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .note-content h2 {
    font-family: 'Crimson Pro', 'Noto Serif SC', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.75rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .note-content h3 {
    font-family: 'Crimson Pro', 'Noto Serif SC', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.25rem 0 0.5rem;
  }
  .note-content h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
  }

  .note-content p {
    margin: 0.75rem 0;
  }

  .note-content ul, .note-content ol {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
  }
  .note-content li {
    margin: 0.4rem 0;
    padding-left: 0.25rem;
  }
  .note-content li > ul, .note-content li > ol {
    margin: 0.25rem 0;
  }

  .note-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
    transition: text-decoration-color 0.2s;
  }
  .note-content a:hover {
    text-decoration-color: var(--accent);
  }

  .note-content code {
    background: var(--bg-elevated);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    color: var(--accent);
  }

  .note-content pre {
    background: #1A1816;
    color: #E0DCD8;
    padding: 1rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.85rem;
    line-height: 1.6;
    border: 1px solid var(--border);
    -webkit-overflow-scrolling: touch;
  }
  .note-content pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .note-content blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    background: var(--bg-elevated);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--text-secondary);
    font-size: 0.9em;
  }
  .note-content blockquote p {
    margin: 0.25rem 0;
  }

  .note-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9em;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .note-content th, .note-content td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    white-space: nowrap;
  }
  .note-content th {
    background: var(--bg-elevated);
    font-weight: 600;
    position: sticky;
    left: 0;
  }
  .note-content tr:nth-child(even) {
    background: var(--bg-elevated);
  }

  .note-content img {
    max-width: 100%;
    border-radius: 0.75rem;
    margin: 1rem 0;
    box-shadow: 0 2px 8px hsl(var(--shadow-color) / 0.08);
  }

  .note-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .note-content strong {
    font-weight: 600;
    color: var(--text-primary);
  }

  .note-content em {
    color: var(--text-secondary);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  // Client-side fallback: fix any [[#...]] links the server-side missed
  document.addEventListener('DOMContentLoaded', () => {
    const content = document.querySelector('.note-content');
    if (!content) return;

    // Build a map of all heading IDs on the page
    const headings = {};
    content.querySelectorAll('h1, h2, h3, h4').forEach(h => {
      if (h.id) {
        headings[h.id.toLowerCase()] = h.id;
      }
    });

    // Find broken anchor links (pointing to non-existent IDs)
    content.querySelectorAll('a[href^="#"]').forEach(link => {
      const targetId = decodeURIComponent(link.getAttribute('href').slice(1));
      if (!document.getElementById(targetId)) {
        // Try to find a matching heading
        const linkText = link.textContent.toLowerCase().trim();
        for (const [slug, id] of Object.entries(headings)) {
          if (linkText.includes(slug.replace(/-/g, '')) || slug.includes(linkText.replace(/\s+/g, '-'))) {
            link.setAttribute('href', '#' + id);
            return;
          }
        }
      }
    });

    // Also handle any remaining raw [[...]] text (shouldn't happen after server-side, but just in case)
    const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT);
    const textNodes = [];
    while (walker.nextNode()) textNodes.push(walker.currentNode);

    textNodes.forEach(node => {
      const text = node.textContent;
      if (!text.includes('[[')) return;
      const regex = /\[\[([^\]]+)\]\]/g;
      let match;
      const parts = [];
      let lastIndex = 0;
      while ((match = regex.exec(text)) !== null) {
        if (match.index > lastIndex) parts.push(document.createTextNode(text.slice(lastIndex, match.index)));
        const raw = match[1];
        let el;
        if (raw.startsWith('#')) {
          // Heading link: [[#heading]]
          const heading = raw.slice(1).split('|')[0];
          let slug = heading.replace(/[\u{1F300}-\u{1F9FF}\u{2600}-\u{27BF}\u{FE00}-\u{FE0F}\u{200D}\u{20E3}\u{E0020}-\u{E007F}]/gu, '').replace(/[^\w\s\u4e00-\u9fff-]/gu, '').toLowerCase().replace(/\s+/g, '-');
          let href = '#' + slug;
          for (const [s, id] of Object.entries(headings)) {
            if (s === slug || s === slug.toLowerCase() || heading.toLowerCase().includes(s.replace(/-/g, ''))) {
              href = '#' + id;
              break;
            }
          }
          el = document.createElement('a');
          el.href = href;
          el.textContent = heading;
        } else {
          // Note link: [[path]] or [[path|display]]
          const [path, display] = raw.split('|');
          const displayText = display?.trim() || path.split('/').pop()?.trim() || path.trim();
          el = document.createElement('a');
          el.href = '/notes/' + path.trim();
          el.textContent = displayText;
        }
        parts.push(el);
        lastIndex = match.index + match[0].length;
      }
      if (lastIndex < text.length) parts.push(document.createTextNode(text.slice(lastIndex)));
      if (parts.length > 0) {
        const frag = document.createDocumentFragment();
        parts.forEach(p => frag.appendChild(p));
        node.parentNode.replaceChild(frag, node);
      }
    });
  });
</script>
