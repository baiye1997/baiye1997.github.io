---
import Layout from '../../layouts/Layout.astro';

// Get all markdown files
const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });

function isPublicNote(path: string): boolean {
  if (path.includes('二掌柜')) return false;
  const filename = path.split('/').pop() || '';
  if (filename === 'README.md') return false;
  if (filename.includes('归档规范')) return false;
  if (filename.includes('排版规范')) return false;
  if (filename.includes('模板')) return false;
  if (filename.startsWith('.')) return false;
  return true;
}

// Build notes data
const allNotes: Record<string, any> = {};
for (const [path, module] of Object.entries(noteFiles)) {
  if (!isPublicNote(path)) continue;
  const parts = path.split('/');
  const category = parts[parts.length - 2] || '其他';
  const filename = parts.pop()?.replace('.md', '') || 'index';
  const slug = `${category}/${filename}`;
  
  allNotes[slug] = {
    title: module.frontmatter?.title || filename,
    date: module.frontmatter?.date || '',
    tags: module.frontmatter?.tags || [],
    category,
    content: module.compiledContent?.() || '',
  };
}

// Generate static paths
export function getStaticPaths() {
  const noteFiles = import.meta.glob('../../../src/content/notes/**/*.md', { eager: true });
  const paths: { params: { slug: string } }[] = [];
  
  for (const path of Object.keys(noteFiles)) {
    if (!isPublicNote(path)) continue;
    const parts = path.split('/');
    const category = parts[parts.length - 2] || '其他';
    const filename = parts.pop()?.replace('.md', '') || 'index';
    paths.push({ params: { slug: `${category}/${filename}` } });
  }
  
  return paths;
}

// Get the slug from the URL
const { slug } = Astro.params;
const note = allNotes[slug || ''];

if (!note) {
  return Astro.redirect('/notes');
}
---

<Layout title={`${note.title} - 白也`}>
  <!-- Back button -->
  <a href="/notes" class="inline-flex items-center gap-1 text-sm text-[#8E8E93] hover:text-[#4169E1] transition-colors mb-6">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    返回笔记
  </a>

  <!-- Note header -->
  <article class="bg-white rounded-2xl p-6 shadow-sm mb-6">
    <div class="flex items-center gap-2 text-sm text-[#8E8E93] mb-3">
      <span class="px-2 py-0.5 rounded-full bg-[#4169E1]/10 text-[#4169E1] text-xs font-medium">
        {note.category}
      </span>
      {note.date && <span>{note.date}</span>}
    </div>
    
    <h1 class="text-[28px] font-bold tracking-tight mb-4">{note.title}</h1>
    
    {note.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {note.tags.map((tag: string) => (
          <span class="px-2 py-0.5 rounded-full bg-[#F2F2F7] text-[#8E8E93] text-xs">
            {tag}
          </span>
        ))}
      </div>
    )}
    
    <!-- Note content -->
    <div class="prose prose-sm max-w-none text-[#3C3C43] leading-relaxed">
      <Fragment set:html={note.content} />
    </div>
  </article>
</Layout>

<style is:global>
  .prose h1 { font-size: 1.5rem; font-weight: 700; margin: 1.5rem 0 0.75rem; }
  .prose h2 { font-size: 1.25rem; font-weight: 600; margin: 1.25rem 0 0.5rem; }
  .prose h3 { font-size: 1.1rem; font-weight: 600; margin: 1rem 0 0.5rem; }
  .prose p { margin: 0.75rem 0; }
  .prose ul, .prose ol { margin: 0.75rem 0; padding-left: 1.5rem; }
  .prose li { margin: 0.25rem 0; }
  .prose a { color: #4169E1; text-decoration: underline; }
  .prose a:hover { color: #6495ED; }
  .prose code { background: #F2F2F7; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; }
  .prose pre { background: #1a1a2e; color: #e0e0e0; padding: 1rem; border-radius: 0.75rem; overflow-x: auto; margin: 1rem 0; }
  .prose pre code { background: transparent; padding: 0; color: inherit; }
  .prose blockquote { border-left: 3px solid #4169E1; padding-left: 1rem; margin: 1rem 0; color: #8E8E93; }
  .prose strong { font-weight: 600; }
  .prose img { max-width: 100%; border-radius: 0.5rem; margin: 1rem 0; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  .prose th, .prose td { border: 1px solid #E5E5EA; padding: 0.5rem 0.75rem; text-align: left; }
  .prose th { background: #F2F2F7; font-weight: 600; }
</style>
