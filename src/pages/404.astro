---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - 页面不存在">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h1 class="text-[28px] font-bold tracking-tight mb-2 dark:text-white">页面不存在</h1>
    <p class="text-[#8E8E93] dark:text-[#98989D] mb-6">你迷路了，这个页面已经搬走了</p>
    <a href="/" class="px-5 py-2.5 rounded-xl bg-[#4169E1] text-white text-sm font-medium hover:bg-[#3456c9] transition-colors">
      回到首页
    </a>
  </div>
</Layout>
