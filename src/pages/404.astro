---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - 页面不存在">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h1 class="font-serif text-[28px] font-bold tracking-tight mb-2" style="color: var(--text-primary);">页面不存在</h1>
    <p class="text-sm mb-6" style="color: var(--text-tertiary);">你迷路了，这个页面已经搬走了</p>
    <a href="/" class="px-5 py-2.5 rounded-xl text-sm font-medium text-white transition-colors" style="background: var(--accent);">
      回到首页
    </a>
  </div>
</Layout>
