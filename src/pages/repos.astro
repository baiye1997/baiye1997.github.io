---
import Layout from '../layouts/Layout.astro';

// Fetch GitHub repos at build time
let repos: any[] = [];
try {
  const response = await fetch('https://api.github.com/users/baiye1997/repos?per_page=100&sort=updated');
  const data = await response.json();
  if (Array.isArray(data)) {
    repos = data
      .filter((r: any) => !r.private)
      .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count)
      .slice(0, 12);
  }
} catch (e) {
  console.error('Failed to fetch repos:', e);
}

const langColors: Record<string, string> = {
  TypeScript: '#3178C6',
  JavaScript: '#F7DF1E',
  Python: '#3572A5',
  HTML: '#E34F26',
  CSS: '#563D7C',
  Vue: '#41B883',
  'C++': '#F34B7D',
  Java: '#B07219',
  Shell: '#89E051',
  Astro: '#FF5D01',
};

const featured = repos[0];
const otherRepos = repos.slice(1);
---

<Layout title="项目 - 白也">
  <!-- Hero -->
  <section class="mb-10 reveal">
    <h1 class="font-serif text-[36px] sm:text-[48px] font-bold tracking-tight mb-3" style="color: var(--text-primary);">项目</h1>
    <p class="text-lg" style="color: var(--text-secondary);">在 GitHub 上分享的一些项目和工具</p>
  </section>

  <div class="dot-divider">·</div>

  <!-- Featured Project -->
  {featured && (
    <section class="mb-10 reveal">
      <a href={featured.html_url} target="_blank" rel="noopener" class="block group">
        <div class="card p-6 sm:p-8 hover:shadow-lg transition-all duration-300" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="flex items-center gap-2 mb-3 text-xs font-mono uppercase tracking-wider" style="color: var(--accent);">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            Featured Project
          </div>
          <h2 class="font-serif text-2xl sm:text-3xl font-bold mb-3 group-hover:text-[var(--accent)] transition-colors" style="color: var(--text-primary);">
            {featured.name}
          </h2>
          <p class="text-base sm:text-lg mb-5 leading-relaxed" style="color: var(--text-secondary);">
            {featured.description || '暂无描述'}
          </p>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--text-tertiary);">
            一个用于管理 Clash/Mihomo 订阅规则的工具项目，帮助用户更好地管理和自定义代理规则。
          </p>
          <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--text-tertiary);">
            {featured.language && (
              <span class="flex items-center gap-1.5">
                <span class="w-3 h-3 rounded-full" style={`background-color: ${langColors[featured.language] || '#8E8E93'}`}></span>
                {featured.language}
              </span>
            )}
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              {featured.stargazers_count} stars
            </span>
            {featured.updated_at && (
              <span>更新于 {new Date(featured.updated_at).toLocaleDateString('zh-CN')}</span>
            )}
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- Other Repos -->
  {otherRepos.length > 0 && (
    <section class="mb-10 reveal">
      <h2 class="font-serif text-xl font-bold mb-4" style="color: var(--text-primary);">其他项目</h2>
      <div class="flex flex-col gap-0" style="border-top: 1px solid var(--border);">
        {otherRepos.map((repo: any) => (
          <a href={repo.html_url} target="_blank" rel="noopener" class="group flex items-center gap-4 py-4 px-2 hover:bg-[var(--bg-elevated)] transition-colors" style="border-bottom: 1px solid var(--border);">
            {repo.language && (
              <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background-color: ${langColors[repo.language] || '#8E8E93'}`}></span>
            )}
            {!repo.language && <span class="w-3 h-3 flex-shrink-0"></span>}
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-sm group-hover:text-[var(--accent)] transition-colors truncate" style="color: var(--text-primary);">{repo.name}</h3>
              <p class="text-xs truncate mt-0.5" style="color: var(--text-tertiary);">{repo.description || '暂无描述'}</p>
            </div>
            <div class="flex items-center gap-1 text-xs flex-shrink-0" style="color: var(--text-tertiary);">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              {repo.stargazers_count}
            </div>
            <span class="text-xs flex-shrink-0 hidden sm:block" style="color: var(--text-tertiary);">
              {repo.updated_at && new Date(repo.updated_at).toLocaleDateString('zh-CN')}
            </span>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="dot-divider">·</div>

  <!-- Tech Stack -->
  <section class="mb-10 reveal">
    <h2 class="font-serif text-xl font-bold mb-4" style="color: var(--text-primary);">我的技术栈</h2>
    <div class="flex flex-wrap gap-2">
      {['HTML', 'CSS', 'JavaScript', 'TypeScript', 'Astro', 'React', 'Vue', 'Python', 'Shell', 'Git', 'GitHub', 'Obsidian', 'VS Code', 'Claude', 'ChatGPT', 'Cursor', '广联达', '宏业'].map(skill => (
        <span class="interest-pill">{skill}</span>
      ))}
    </div>
  </section>

  <div class="dot-divider">·</div>

  <!-- Open Source Philosophy -->
  <section class="mb-10 reveal">
    <blockquote class="relative pl-6 py-2" style="border-left: 3px solid var(--accent);">
      <p class="font-serif text-xl sm:text-2xl italic leading-relaxed" style="color: var(--text-primary);">
        "相信开源的力量，代码应该被分享。"
      </p>
    </blockquote>
  </section>

  <div class="dot-divider">·</div>

  <!-- Heatmap -->
  <section id="heatmap" class="reveal">
    <h2 class="font-serif text-lg font-bold mb-4" style="color: var(--text-primary);">贡献热力图</h2>
    <p class="text-sm mb-4" style="color: var(--text-tertiary);">过去一年的 GitHub 贡献记录</p>
    
    <div id="heatmap-container" class="overflow-x-auto pb-2">
      <div class="flex items-end gap-[3px] min-w-[720px]"></div>
    </div>
    
    <div class="flex items-center justify-end gap-2 mt-3 text-xs" style="color: var(--text-tertiary)">
      <span>少</span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #ebedf0"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #9be9a8"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #40c463"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #30a14e"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #216e39"></span>
      <span>多</span>
    </div>
  </section>
</Layout>

<script is:inline>
  async function renderHeatmap() {
    const container = document.querySelector('#heatmap-container .flex');
    if (!container) return;

    try {
      const response = await fetch('https://github-contributions-api.jogruber.de/v4/baiye1997');
      const data = await response.json();
      const contributions = data.contributions || [];
      
      const weeks = [];
      let currentWeek = [];
      
      const today = new Date();
      const startDate = new Date(today);
      startDate.setDate(startDate.getDate() - 364);
      startDate.setDate(startDate.getDate() - startDate.getDay());
      
      const dateMap = {};
      contributions.forEach(c => { dateMap[c.date] = c.count; });
      
      const currentDate = new Date(startDate);
      while (currentDate <= today) {
        const dateStr = currentDate.toISOString().split('T')[0];
        const count = dateMap[dateStr] || 0;
        currentWeek.push({ date: dateStr, count });
        
        if (currentDate.getDay() === 6 || currentDate.getTime() >= today.getTime()) {
          weeks.push(currentWeek);
          currentWeek = [];
        }
        currentDate.setDate(currentDate.getDate() + 1);
      }
      if (currentWeek.length > 0) weeks.push(currentWeek);
      
      const colors = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
      
      container.innerHTML = weeks.map(week => `
        <div class="flex flex-col gap-[3px]">
          ${week.map(day => {
            const level = day.count === 0 ? 0 : 
                         day.count <= 2 ? 1 : 
                         day.count <= 5 ? 2 : 
                         day.count <= 10 ? 3 : 4;
            return `<div class="w-3 h-3 rounded-sm hover:scale-125 transition-transform" style="background-color: ${colors[level]}" title="${day.date}: ${day.count} 次贡献"></div>`;
          }).join('')}
        </div>
      `).join('');
      
    } catch (e) {
      container.innerHTML = '<p class="text-sm" style="color: var(--text-tertiary)">热力图加载失败，请稍后再试</p>';
    }
  }
  
  renderHeatmap();
</script>
