---
import Layout from '../layouts/Layout.astro';

// Fetch GitHub repos at build time
let repos = [];
try {
  const response = await fetch('https://api.github.com/users/baiye1997/repos?per_page=100&sort=updated');
  repos = await response.json();
  repos = repos
    .filter((r: any) => !r.private)
    .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count)
    .slice(0, 12);
} catch (e) {
  console.error('Failed to fetch repos:', e);
}

const langColors: Record<string, string> = {
  TypeScript: '#3178C6',
  JavaScript: '#F7DF1E',
  Python: '#3572A5',
  HTML: '#E34F26',
  CSS: '#563D7C',
  Vue: '#41B883',
  'C++': '#F34B7D',
  Java: '#B07219',
  Shell: '#89E051',
  Astro: '#FF5D01',
};
---

<Layout title="项目 - 白也">
  <section class="mb-8">
    <h1 class="text-[34px] font-bold tracking-tight mb-2 dark:text-white">项目</h1>
    <p class="text-[#8E8E93] dark:text-[#98989D]">GitHub 上的开源仓库</p>
  </section>

  <!-- Repos -->
  <section class="mb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {repos.map((repo: any) => (
        <a href={repo.html_url} target="_blank" rel="noopener" class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-5 block group shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-semibold text-base group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors truncate dark:text-[#EBEBF5]">
              {repo.name}
            </h3>
            <div class="flex items-center gap-1 text-sm text-[#8E8E93] dark:text-[#98989D] flex-shrink-0">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              {repo.stargazers_count}
            </div>
          </div>
          <p class="text-sm text-[#8E8E93] dark:text-[#98989D] line-clamp-2 mb-3">
            {repo.description || '暂无描述'}
          </p>
          <div class="flex items-center gap-3 text-xs text-[#8E8E93] dark:text-[#98989D]">
            {repo.language && (
              <span class="flex items-center gap-1">
                <span class="w-2.5 h-2.5 rounded-full" style={`background-color: ${langColors[repo.language] || '#8E8E93'}`}></span>
                {repo.language}
              </span>
            )}
            {repo.fork && (
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Fork
              </span>
            )}
            {repo.updated_at && (
              <span>更新于 {new Date(repo.updated_at).toLocaleDateString('zh-CN')}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Heatmap -->
  <section id="heatmap" class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-4 dark:text-white">贡献热力图</h2>
    <p class="text-sm text-[#8E8E93] dark:text-[#98989D] mb-4">过去一年的 GitHub 贡献记录</p>
    
    <div id="heatmap-container" class="overflow-x-auto pb-2">
      <div class="flex items-end gap-[3px] min-w-[720px]"></div>
    </div>
    
    <div class="flex items-center justify-end gap-2 mt-3 text-xs text-[#8E8E93] dark:text-[#98989D]">
      <span>少</span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #ebedf0"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #9be9a8"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #40c463"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #30a14e"></span>
      <span class="w-3 h-3 rounded-sm" style="background-color: #216e39"></span>
      <span>多</span>
    </div>
  </section>
</Layout>

<script is:inline>
  async function renderHeatmap() {
    const container = document.querySelector('#heatmap-container .flex');
    if (!container) return;

    try {
      const response = await fetch('https://github-contributions-api.jogruber.de/v4/baiye1997');
      const data = await response.json();
      const contributions = data.contributions || [];
      
      const weeks = [];
      let currentWeek = [];
      
      const today = new Date();
      const startDate = new Date(today);
      startDate.setDate(startDate.getDate() - 364);
      startDate.setDate(startDate.getDate() - startDate.getDay());
      
      const dateMap = {};
      contributions.forEach(c => { dateMap[c.date] = c.count; });
      
      const currentDate = new Date(startDate);
      while (currentDate <= today) {
        const dateStr = currentDate.toISOString().split('T')[0];
        const count = dateMap[dateStr] || 0;
        currentWeek.push({ date: dateStr, count });
        
        if (currentDate.getDay() === 6 || currentDate.getTime() >= today.getTime()) {
          weeks.push(currentWeek);
          currentWeek = [];
        }
        currentDate.setDate(currentDate.getDate() + 1);
      }
      if (currentWeek.length > 0) weeks.push(currentWeek);
      
      const colors = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
      
      container.innerHTML = weeks.map(week => `
        <div class="flex flex-col gap-[3px]">
          ${week.map(day => {
            const level = day.count === 0 ? 0 : 
                         day.count <= 2 ? 1 : 
                         day.count <= 5 ? 2 : 
                         day.count <= 10 ? 3 : 4;
            return `<div class="w-3 h-3 rounded-sm hover:scale-125 transition-transform" style="background-color: ${colors[level]}" title="${day.date}: ${day.count} 次贡献"></div>`;
          }).join('')}
        </div>
      `).join('');
      
    } catch (e) {
      container.innerHTML = '<p class="text-[#8E8E93] dark:text-[#98989D] text-sm">热力图加载失败，请稍后再试</p>';
    }
  }
  
  renderHeatmap();
</script>
