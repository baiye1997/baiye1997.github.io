---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 - 白也">
  <section class="mb-8">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-20 h-20 rounded-2xl gradient-blue flex items-center justify-center text-4xl shadow-lg shadow-ios-blue/20">
        B
      </div>
      <div>
        <h1 class="ios-large-title">白也</h1>
        <p class="text-ios-gray">baiye1997</p>
      </div>
    </div>
  </section>

  <!-- About me -->
  <section class="ios-card p-6 mb-6">
    <h2 class="ios-section-header mb-3">关于我</h2>
    <div class="space-y-3 text-sm text-ios-secondary-label leading-relaxed">
      <p>
        成都开发者，白天写代码，晚上看基金。养了一只叫花花的猫 🐱
      </p>
      <p>
        喜欢用技术解决生活中的小问题，从基金投资管理到日常工具，能自动化的绝不手动。
      </p>
      <p>
        目前在成都双流区工作，每天从温江开车通勤（即将搬到双流，通勤距离大幅缩短 🎉）。
      </p>
    </div>
  </section>

  <!-- Tech stack -->
  <section class="ios-card p-6 mb-6">
    <h2 class="ios-section-header mb-3">技术栈</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">⚛️</span>
        <span class="text-sm font-medium">React</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">💚</span>
        <span class="text-sm font-medium">Vue</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">📘</span>
        <span class="text-sm font-medium">TypeScript</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">🐍</span>
        <span class="text-sm font-medium">Python</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">📱</span>
        <span class="text-sm font-medium">Capacitor</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-black/5">
        <span class="text-lg">🚀</span>
        <span class="text-sm font-medium">Astro</span>
      </div>
    </div>
  </section>

  <!-- 花花日记 -->
  <section id="huahua" class="ios-card overflow-hidden mb-6">
    <div class="gradient-orange p-6 text-white">
      <div class="text-4xl mb-2">🐱</div>
      <h2 class="text-2xl font-bold">花花日记</h2>
      <p class="text-white/80 text-sm mt-1">基金投资管理助手</p>
    </div>
    <div class="p-6">
      <div class="space-y-3 text-sm text-ios-secondary-label leading-relaxed">
        <p>
          花花日记是一个帮助你管理基金投资的工具。支持 PWA 和 Android 端，
          帮你追踪持仓、计算收益、查看行情。
        </p>
        <p>
          技术栈：React + Capacitor，一套代码同时支持 Web 和移动端。
        </p>
        <div class="flex flex-wrap gap-2 pt-2">
          <span class="px-3 py-1 rounded-full bg-ios-green/10 text-ios-green text-xs font-medium">PWA</span>
          <span class="px-3 py-1 rounded-full bg-ios-blue/10 text-ios-blue text-xs font-medium">Android</span>
          <span class="px-3 py-1 rounded-full bg-ios-orange/10 text-ios-orange text-xs font-medium">React</span>
          <span class="px-3 py-1 rounded-full bg-ios-purple/10 text-ios-purple text-xs font-medium">Capacitor</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="ios-card p-6">
    <h2 class="ios-section-header mb-3">联系我</h2>
    <div class="space-y-3">
      <a href="https://github.com/baiye1997" target="_blank" class="flex items-center gap-3 p-3 rounded-xl hover:bg-black/5 transition-colors group">
        <span class="text-2xl">🐙</span>
        <div>
          <div class="text-sm font-medium group-hover:text-ios-blue transition-colors">GitHub</div>
          <div class="text-xs text-ios-gray">@baiye1997</div>
        </div>
      </a>
    </div>
  </section>
</Layout>
