---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 - 白也">
  <section class="flex items-center gap-4 mb-8">
    <img src="/avatar.jpg" alt="白也" class="w-20 h-20 rounded-2xl object-cover shadow-lg" loading="eager" />
    <div>
      <h1 class="text-[34px] font-bold tracking-tight dark:text-white">白也</h1>
      <p class="text-[#8E8E93] dark:text-[#98989D]">baiye1997</p>
    </div>
  </section>

  <!-- About -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 mb-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-3 dark:text-white">关于我</h2>
    <div class="space-y-3 text-sm text-[#3C3C43] dark:text-[#EBEBF5] leading-relaxed">
      <p>安装工程造价师，喜欢用 AI 解决生活中的各种问题，热衷尝试各种 AI 应用。养了一只叫花花的猫 🐱</p>
      <p>做了<a href="/huahua" class="text-[#4169E1] dark:text-[#6495ED] hover:underline">花花日记</a>来管理基金投资，用 Obsidian 记录生活和学习笔记，偶尔在 <a href="https://github.com/baiye1997" target="_blank" class="text-[#4169E1] dark:text-[#6495ED] hover:underline">GitHub</a> 上分享一些项目。</p>
    </div>
  </section>

  <!-- Tools -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 mb-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-3 dark:text-white">我用的工具</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🤖</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">Claude</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🧠</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">ChatGPT</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">📝</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">Obsidian</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🐙</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">GitHub</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🎨</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">广联达</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">💻</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">宏业</span>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-3 dark:text-white">联系我</h2>
    <a href="https://github.com/baiye1997" target="_blank" class="flex items-center gap-3 p-3 rounded-xl hover:bg-[#F2F2F7] dark:hover:bg-[#2C2C2E] transition-colors group">
      <span class="text-2xl">🐙</span>
      <div>
        <div class="text-sm font-medium group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors dark:text-[#EBEBF5]">GitHub</div>
        <div class="text-xs text-[#8E8E93] dark:text-[#98989D]">@baiye1997</div>
      </div>
    </a>
  </section>
</Layout>
