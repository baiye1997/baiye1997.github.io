---
import Layout from '../layouts/Layout.astro';
---

<Layout title="花花日记 - 白也">
  <!-- Hero — prominent with larger logo and tagline -->
  <section class="flex flex-col items-center text-center mb-12 reveal">
    <img src="/huahua-logo.jpg" alt="花花日记" class="w-24 h-24 rounded-3xl object-cover shadow-lg mb-5" loading="eager" />
    <h1 class="font-serif text-[36px] font-bold tracking-tight mb-2" style="color: var(--text-primary);">花花日记</h1>
    <p class="text-base" style="color: var(--text-secondary);">让基金投资更简单</p>
  </section>

  <!-- Tags -->
  <div class="flex flex-wrap justify-center gap-2 mb-10 reveal reveal-delay-1">
    <span class="tag">PWA</span>
    <span class="tag">Android</span>
    <span class="tag">实时估值</span>
  </div>

  <!-- Stats — larger numbers, subtle gradient backgrounds -->
  <section id="huahua-stats" class="mb-10 reveal reveal-delay-2">
    <div id="huahua-stats-content" class="grid grid-cols-3 gap-4">
      <div class="text-center p-5 rounded-xl" style="background: linear-gradient(135deg, var(--bg-elevated), var(--bg-card));">
        <div class="text-3xl font-bold" style="color: var(--accent);">--</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">今日访问</div>
      </div>
      <div class="text-center p-5 rounded-xl" style="background: linear-gradient(135deg, var(--bg-elevated), var(--bg-card));">
        <div class="text-3xl font-bold" style="color: var(--sage);">--</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">活跃用户</div>
      </div>
      <div class="text-center p-5 rounded-xl" style="background: linear-gradient(135deg, var(--bg-elevated), var(--bg-card));">
        <div class="text-3xl font-bold" style="color: var(--accent);">--</div>
        <div class="text-xs mt-1" style="color: var(--text-tertiary);">总用户</div>
      </div>
    </div>
    <div id="huahua-stats-error" class="hidden text-center py-4 text-sm" style="color: var(--text-tertiary);">
      暂无数据
    </div>
  </section>

  <!-- Features — 2-column grid of mini-cards -->
  <section class="mb-10 reveal reveal-delay-3">
    <h2 class="font-serif text-lg font-bold mb-5" style="color: var(--text-primary);">核心功能</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="card p-4">
        <div class="text-2xl mb-2">⚡</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">实时估值</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">盘中实时估算基金净值，人无我有的核心功能</p>
      </div>
      <div class="card p-4">
        <div class="text-2xl mb-2">📊</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">持仓追踪</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">实时查看基金持仓、成本、收益，一目了然</p>
      </div>
      <div class="card p-4">
        <div class="text-2xl mb-2">🔄</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">定投管理</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">支持设定定投计划，自动追踪定投收益</p>
      </div>
      <div class="card p-4">
        <div class="text-2xl mb-2">🏷️</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">基金标签</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">自定义标签分类管理，灵活组织你的基金</p>
      </div>
      <div class="card p-4">
        <div class="text-2xl mb-2">🌍</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">海外基金夜盘估算</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">支持 QDII 等海外基金，夜间也能看估值</p>
      </div>
      <div class="card p-4">
        <div class="text-2xl mb-2">📸</div>
        <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);">截图导入</h3>
        <p class="text-xs leading-relaxed" style="color: var(--text-tertiary);">截图导入持仓和交易记录，告别手动录入</p>
      </div>
    </div>
  </section>

  <!-- 界面预览 -->
  <section class="mb-10 reveal">
    <h2 class="font-serif text-lg font-bold mb-4" style="color: var(--text-primary);">界面预览</h2>
    <div class="relative group">
      <button onclick="scrollScreenshots(-1)" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 z-10 w-9 h-9 rounded-full items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 hidden sm:flex opacity-0 group-hover:opacity-100" style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <div class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide scroll-smooth" id="screenshot-scroll">
      <img src="/huahua-screenshots/01-资产卡片.jpg" alt="资产卡片" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/02-资列表.jpg" alt="资产列表" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/03-资产表格.jpg" alt="资产表格" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/04-自选观察.jpg" alt="自选观察" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/05-猫舍分析.jpg" alt="猫舍分析" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/06-打卡日历.jpg" alt="打卡日历" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/07-储粮记录.jpg" alt="储粮记录" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/08-市场全景.jpg" alt="市场全景" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/09-涨幅排行.jpg" alt="涨幅排行" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/10-板块榜.jpg" alt="板块榜" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/11-夜盘估算.jpg" alt="夜盘估算" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      <img src="/huahua-screenshots/12-设置页.jpg" alt="设置页" class="screenshot-item flex-shrink-0 rounded-2xl cursor-pointer" style="height: 260px; width: auto; object-fit: cover; border: 1px solid var(--border);" loading="lazy" onclick="openLightbox(this)" />
      </div>
      <button onclick="scrollScreenshots(1)" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 z-10 w-9 h-9 rounded-full items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 hidden sm:flex opacity-0 group-hover:opacity-100" style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
    <p class="text-center text-xs mt-2" style="color: var(--text-tertiary);">← 左右滑动查看更多 →</p>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[999] hidden items-center justify-center" style="background: rgba(0,0,0,0.92); backdrop-filter: blur(8px);" onclick="closeLightbox(event)">
    <button onclick="closeLightbox(event)" class="absolute top-5 right-5 w-10 h-10 rounded-full flex items-center justify-center z-[1001] transition-all duration-200 hover:scale-110" style="background: rgba(255,255,255,0.15); color: #fff;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] rounded-2xl shadow-2xl transition-transform duration-300 ease-out" style="object-fit: contain;" onclick="event.stopPropagation()" />
  </div>

  <style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .screenshot-item { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .screenshot-item:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
    #lightbox { opacity: 0; transition: opacity 0.3s ease; }
    #lightbox.active { opacity: 1; }
    #lightbox-img { transform: scale(0.92); opacity: 0; transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.25s ease; }
    #lightbox.active #lightbox-img { transform: scale(1); opacity: 1; }
  </style>

  <script is:inline>
    function openLightbox(el) {
      const lb = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img');
      img.src = el.src;
      img.alt = el.alt;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      requestAnimationFrame(() => { lb.classList.add('active'); });
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox(e) {
      const lb = document.getElementById('lightbox');
      lb.classList.remove('active');
      setTimeout(() => { lb.classList.add('hidden'); lb.classList.remove('flex'); }, 300);
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
    function scrollScreenshots(dir) {
      const el = document.getElementById('screenshot-scroll');
      el.scrollBy({ left: dir * 280, behavior: 'smooth' });
    }
  </script>

  <!-- Testimonials -->
  <section class="mb-10 reveal">
    <h2 class="font-serif text-lg font-bold mb-5" style="color: var(--text-primary);">用户说</h2>
    <div class="space-y-4">
      <div class="pl-4" style="border-left: 3px solid var(--accent);">
        <p class="text-sm italic" style="color: var(--text-secondary);">"终于不用打开天天基金看估值了"</p>
        <p class="text-xs mt-1" style="color: var(--text-tertiary);">— 一位基民</p>
      </div>
      <div class="pl-4" style="border-left: 3px solid var(--sage);">
        <p class="text-sm italic" style="color: var(--text-secondary);">"截图导入功能太方便了"</p>
        <p class="text-xs mt-1" style="color: var(--text-tertiary);">— 量化投资者</p>
      </div>
      <div class="pl-4" style="border-left: 3px solid var(--accent);">
        <p class="text-sm italic" style="color: var(--text-secondary);">"界面简洁，比支付宝好用"</p>
        <p class="text-xs mt-1" style="color: var(--text-tertiary);">— 理财小白</p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="dot-divider my-8"></div>

  <!-- Download — simple links, not cards -->
  <section class="mb-10 reveal">
    <h2 class="font-serif text-lg font-bold mb-5" style="color: var(--text-primary);">下载体验</h2>
    <div class="space-y-0">
      <a href="https://huahuadaily.preview.aliyun-zeabur.cn" target="_blank" class="flex items-center justify-between py-3.5 group" style="border-bottom: 1px solid var(--border);">
        <div class="flex items-center gap-3">
          <span>🌐</span>
          <div>
            <div class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors" style="color: var(--text-primary);">网页版 (PWA)</div>
            <div class="text-xs" style="color: var(--text-tertiary);">直接在浏览器中使用</div>
          </div>
        </div>
        <svg class="w-4 h-4" style="color: var(--border);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      <a href="https://1812237070.share.123pan.cn/123pan/k8yrVv-NjFhd" target="_blank" class="flex items-center justify-between py-3.5 group" style="border-bottom: 1px solid var(--border);">
        <div class="flex items-center gap-3">
          <span>📱</span>
          <div>
            <div class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors" style="color: var(--text-primary);">Android App</div>
            <div class="text-xs" style="color: var(--text-tertiary);">下载 APK 安装到手机</div>
          </div>
        </div>
        <svg class="w-4 h-4" style="color: var(--border);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
      </a>
    </div>
  </section>

  <!-- JCTI — subtle callout, not a card -->
  <a href="https://huahuadaily.preview.aliyun-zeabur.cn/?invite=82473898&jcti=1" target="_blank" class="block py-3.5 group reveal" style="border-bottom: 1px solid var(--border);">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span>🧬</span>
        <div>
          <div class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors" style="color: var(--text-primary);">韭菜投资人格测试</div>
          <div class="text-xs" style="color: var(--text-tertiary);">测测你是什么类型的投资者？3 分钟出结果</div>
        </div>
      </div>
      <svg class="w-4 h-4" style="color: var(--border);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </div>
  </a>

  <!-- Tech — just a line of text -->
  <section class="mt-8 reveal">
    <p class="text-xs" style="color: var(--text-tertiary);">技术栈：React · Capacitor · AI 辅助开发 · PWA</p>
  </section>
</Layout>

<script is:inline>
  const HUAHUA_API_URL = 'https://huahua.preview.aliyun-zeabur.cn/api/public/blog-stats';
  const HUAHUA_API_KEY='hf_blog_stats_2026_4vF8kQm2Zr7Lp9Nx6Tw3Yc1Hd5Sa';
  let _huahuaData = null;

  function renderStats(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return;
    const isDark = document.documentElement.classList.contains('dark');
    const bg = isDark ? '#252320' : '#F5F0EB';
    const lc = isDark ? '#A09890' : '#6B6560';
    if (!_huahuaData) return;
    const d = _huahuaData;
    el.innerHTML = [
      [d.today_visit_count, '今日访问', 'var(--accent)'],
      [d.today_logged_in_users, '今日登录', 'var(--sage)'],
      [d.today_visitor_users, '今日访客', 'var(--accent)'],
      [d.total_users, '总用户', 'var(--sage)'],
      [d.total_pro_users, 'Pro 用户', '#D4A03A'],
      [d.total_vip_users, 'VIP 用户', '#D4A03A'],
    ].map(([v, label, color]) =>
      `<div class="text-center p-4 rounded-xl" style="background:${bg}">
        <div class="text-2xl font-bold" style="color:${color}">${v ?? '--'}</div>
        <div class="text-xs mt-1" style="color:${lc}">${label}</div>
      </div>`
    ).join('');
  }

  async function fetchHuahuaStats() {
    if (!HUAHUA_API_URL || !HUAHUA_API_KEY) {
      document.getElementById('huahua-stats-error')?.classList.remove('hidden');
      document.getElementById('huahua-stats-content')?.classList.add('hidden');
      return;
    }
    try {
      const res = await fetch(HUAHUA_API_URL, { headers: { 'Authorization': `Bearer ${HUAHUA_API_KEY}` } });
      if (!res.ok) throw new Error('API failed');
      _huahuaData = await res.json();
      renderStats('huahua-stats-content');
    } catch (e) {
      console.error('Huahua stats error:', e);
      document.getElementById('huahua-stats-error')?.classList.remove('hidden');
      document.getElementById('huahua-stats-content')?.classList.add('hidden');
    }
  }

  fetchHuahuaStats();

  new MutationObserver(() => { if (_huahuaData) renderStats('huahua-stats-content'); })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
