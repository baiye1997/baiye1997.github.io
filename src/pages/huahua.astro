---
import Layout from '../layouts/Layout.astro';
---

<Layout title="花花日记 - 白也">
  <!-- Hero -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm mb-6 flex items-center gap-5">
    <img src="/huahua-logo.jpg" alt="花花日记" class="w-20 h-20 rounded-2xl object-cover" loading="eager" />
    <div class="flex-1 min-w-0">
      <h1 class="text-[28px] font-bold tracking-tight mb-1 dark:text-white">花花日记</h1>
      <p class="text-[#8E8E93] dark:text-[#98989D] text-sm">基金投资管理助手</p>
      <div class="flex flex-wrap gap-1.5 mt-3">
        <span class="px-2.5 py-0.5 rounded-full bg-[#F2F2F7] dark:bg-[#2C2C2E] text-[#636366] dark:text-[#AEAEB2] text-xs">PWA</span>
        <span class="px-2.5 py-0.5 rounded-full bg-[#F2F2F7] dark:bg-[#2C2C2E] text-[#636366] dark:text-[#AEAEB2] text-xs">Android</span>
        <span class="px-2.5 py-0.5 rounded-full bg-[#F2F2F7] dark:bg-[#2C2C2E] text-[#636366] dark:text-[#AEAEB2] text-xs">实时估值</span>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="huahua-stats" class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm mb-6">
    <h2 class="text-[22px] font-bold tracking-tight mb-4 dark:text-white">实时数据</h2>
    <div id="huahua-stats-content" class="grid grid-cols-3 gap-4">
      <div class="text-center p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <div class="text-2xl font-bold text-[#4169E1] dark:text-[#6495ED]">--</div>
        <div class="text-xs text-[#8E8E93] dark:text-[#98989D] mt-1">今日访问</div>
      </div>
      <div class="text-center p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <div class="text-2xl font-bold text-[#6495ED] dark:text-[#4169E1]">--</div>
        <div class="text-xs text-[#8E8E93] dark:text-[#98989D] mt-1">活跃用户</div>
      </div>
      <div class="text-center p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <div class="text-2xl font-bold text-[#4169E1] dark:text-[#6495ED]">--</div>
        <div class="text-xs text-[#8E8E93] dark:text-[#98989D] mt-1">总用户</div>
      </div>
      <div class="text-center p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <div class="text-2xl font-bold text-[#F06292]">--</div>
        <div class="text-xs text-[#8E8E93] dark:text-[#98989D] mt-1">Pro 用户</div>
      </div>
    </div>
    <div id="huahua-stats-error" class="hidden text-center py-4 text-sm text-[#8E8E93] dark:text-[#98989D]">
      暂无数据
    </div>
  </section>

  <!-- Features -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm mb-6">
    <h2 class="text-[22px] font-bold tracking-tight mb-4 dark:text-white">核心功能</h2>
    <div class="space-y-4">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#F06292]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">⚡</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">实时估值</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">盘中实时估算基金净值，人无我有的核心功能</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#4169E1]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">📊</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">持仓追踪</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">实时查看基金持仓、成本、收益，一目了然</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#6495ED]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">🔄</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">定投管理</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">支持设定定投计划，自动追踪定投收益</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#34C759]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">🏷️</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">基金标签</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">自定义标签分类管理，灵活组织你的基金</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#FF9500]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">🌍</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">海外基金夜盘估算</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">支持 QDII 等海外基金，夜间也能看估值</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#AF52DE]/10 flex items-center justify-center flex-shrink-0">
          <span class="text-lg">📸</span>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-0.5 dark:text-[#EBEBF5]">截图导入</h3>
          <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">截图导入持仓和交易记录，告别手动录入</p>
        </div>
      </div>
    </div>
  </section>

  <!-- JCTI -->
  <a href="https://huahuadaily.preview.aliyun-zeabur.cn/?invite=82473898&jcti=1" target="_blank" class="block bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm mb-6 hover:shadow-md transition-shadow">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-2xl bg-[#FF6B6B]/10 flex items-center justify-center flex-shrink-0">
        <span class="text-2xl">🧬</span>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-bold text-base mb-0.5 dark:text-[#EBEBF5]">韭菜投资人格测试</h3>
        <p class="text-xs text-[#8E8E93] dark:text-[#98989D]">测测你是什么类型的投资者？3 分钟出结果</p>
      </div>
      <svg class="w-5 h-5 text-[#C6C6C8] dark:text-[#48484A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </div>
  </a>

  <!-- Download -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm mb-6">
    <h2 class="text-[22px] font-bold tracking-tight mb-4 dark:text-white">下载体验</h2>
    <div class="space-y-3">
      <a href="https://huahuadaily.preview.aliyun-zeabur.cn" target="_blank" class="flex items-center gap-3 p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E] hover:bg-[#E8E8ED] dark:hover:bg-[#3A3A3C] transition-colors group">
        <div class="w-10 h-10 rounded-xl bg-[#4169E1]/10 flex items-center justify-center">
          <span class="text-lg">🌐</span>
        </div>
        <div class="flex-1">
          <div class="text-sm font-medium group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors dark:text-[#EBEBF5]">网页版 (PWA)</div>
          <div class="text-xs text-[#8E8E93] dark:text-[#98989D]">直接在浏览器中使用</div>
        </div>
        <svg class="w-5 h-5 text-[#C6C6C8] dark:text-[#48484A] group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      <a href="https://1812237070.share.123pan.cn/123pan/k8yrVv-CyFhd" target="_blank" class="flex items-center gap-3 p-4 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E] hover:bg-[#E8E8ED] dark:hover:bg-[#3A3A3C] transition-colors group">
        <div class="w-10 h-10 rounded-xl bg-[#34C759]/10 flex items-center justify-center">
          <span class="text-lg">📱</span>
        </div>
        <div class="flex-1">
          <div class="text-sm font-medium group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors dark:text-[#EBEBF5]">Android App</div>
          <div class="text-xs text-[#8E8E93] dark:text-[#98989D]">下载 APK 安装到手机</div>
        </div>
        <svg class="w-5 h-5 text-[#C6C6C8] dark:text-[#48484A] group-hover:text-[#4169E1] dark:group-hover:text-[#6495ED] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Tech -->
  <section class="bg-white dark:bg-[#1C1C1E] rounded-2xl p-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-4 dark:text-white">技术栈</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">⚛️</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">React</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">📱</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">Capacitor</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🤖</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">AI 辅助开发</span>
      </div>
      <div class="flex items-center gap-2 p-3 rounded-xl bg-[#F2F2F7] dark:bg-[#2C2C2E]">
        <span class="text-lg">🌐</span>
        <span class="text-sm font-medium dark:text-[#EBEBF5]">PWA</span>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const HUAHUA_API_URL = 'https://huahua.preview.aliyun-zeabur.cn/api/public/blog-stats';
  const HUAHUA_API_KEY='hf_blo...d5Sa';

  async function fetchHuahuaStats() {
    if (!HUAHUA_API_URL || !HUAHUA_API_KEY) {
      document.getElementById('huahua-stats-error').classList.remove('hidden');
      document.getElementById('huahua-stats-content').classList.add('hidden');
      return;
    }

    try {
      const response = await fetch(HUAHUA_API_URL, {
        headers: { 'Authorization': `Bearer ${HUAHUA_API_KEY}` },
      });

      if (!response.ok) throw new Error('API request failed');

      const data = await response.json();

      const isDark = document.documentElement.classList.contains('dark');
      const cardBg = isDark ? '#2C2C2E' : '#F2F2F7';
      const labelColor = isDark ? '#98989D' : '#8E8E93';

      document.getElementById('huahua-stats-content').innerHTML = `
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#4169E1]">${data.today_visit_count ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">今日访问</div>
        </div>
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#6495ED]">${data.today_logged_in_users ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">今日登录</div>
        </div>
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#4169E1]">${data.today_visitor_users ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">今日访客</div>
        </div>
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#6495ED]">${data.total_users ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">总用户</div>
        </div>
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#F06292]">${data.total_pro_users ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">Pro 用户</div>
        </div>
        <div class="text-center p-4 rounded-xl" style="background-color:${cardBg}">
          <div class="text-2xl font-bold text-[#F06292]">${data.total_vip_users ?? '--'}</div>
          <div class="text-xs mt-1" style="color:${labelColor}">VIP 用户</div>
        </div>
      `;
    } catch (e) {
      console.error('Failed to fetch Huahua stats:', e);
      document.getElementById('huahua-stats-error').classList.remove('hidden');
      document.getElementById('huahua-stats-content').classList.add('hidden');
    }
  }

  fetchHuahuaStats();
</script>
