---
import Layout from '../layouts/Layout.astro';

// Count public notes
const noteFiles = import.meta.glob('../../src/content/notes/**/*.md', { eager: true });
const noteCount = Object.keys(noteFiles).filter(path => {
  if (path.includes('二掌柜')) return false;
  const f = path.split('/').pop() || '';
  if (f === 'README.md' || f.includes('归档规范') || f.includes('排版规范') || f.includes('模板') || f.startsWith('.')) return false;
  return true;
}).length;

// Fetch GitHub repos count at build time
let repoCount = 0;
try {
  const response = await fetch('https://api.github.com/users/baiye1997/repos?per_page=100');
  const repos = await response.json();
  if (Array.isArray(repos)) {
    repoCount = repos.filter((r: any) => !r.private).length;
  }
} catch (e) {
  console.error('Failed to fetch repos:', e);
}

const sections = [
  {
    title: '笔记',
    subtitle: '来自 Obsidian 的知识沉淀',
    icon: '📝',
    href: '/notes',
    color: 'var(--accent)',
  },
  {
    title: '项目',
    subtitle: 'GitHub 开源仓库 · 贡献热力图',
    icon: '💻',
    href: '/repos',
    color: 'var(--sage)',
  },
  {
    title: '花花日记',
    subtitle: '基金投资助手 · PWA + Android',
    icon: '🌸',
    href: '/huahua',
    color: '#D4A03A',
  },
];

// Time-based greeting
const hour = new Date().getHours();
const greeting = hour < 6 ? '夜深了' : hour < 12 ? '早上好' : hour < 18 ? '下午好' : '晚上好';
---

<Layout title="白也 - 个人主页">
  <!-- Hero -->
  <section class="mb-16 reveal">
    <p class="text-sm font-medium mb-3 tracking-wide" style="color: var(--text-tertiary);">
      {greeting} <span class="inline-block animate-[wiggle_2s_ease-in-out_infinite]">👋</span>
    </p>
    <h1 class="font-serif text-[40px] sm:text-[52px] font-bold leading-[1.1] tracking-tight mb-4" style="color: var(--text-primary);">
      我是白也<span style="color: var(--accent);">.</span>
    </h1>
    <p class="text-base sm:text-lg leading-relaxed max-w-lg" style="color: var(--text-secondary);">
      安装工程造价师，业余时间用 AI 搭各种好玩的东西。养了一只叫花花的猫，它才是这个家的主人。
    </p>
  </section>

  <!-- Stats — editorial style -->
  <section class="flex items-center gap-8 mb-14 reveal reveal-delay-1">
    <div class="flex items-baseline gap-2">
      <span class="font-serif text-3xl font-bold" style="color: var(--accent);">{noteCount}</span>
      <span class="text-sm" style="color: var(--text-tertiary);">篇笔记</span>
    </div>
    <div class="w-px h-5" style="background: var(--border);"></div>
    <div class="flex items-baseline gap-2">
      <span class="font-serif text-3xl font-bold" style="color: var(--sage);">{repoCount || '—'}</span>
      <span class="text-sm" style="color: var(--text-tertiary);">个开源项目</span>
    </div>
  </section>

  <!-- 花花日记 — featured card -->
  <a href="/huahua" class="block card card-accent p-6 sm:p-8 mb-10 reveal reveal-delay-2 group">
    <div class="flex items-start justify-between mb-5">
      <div class="flex items-center gap-3">
        <img src="/huahua-logo.jpg" alt="花花日记" class="w-11 h-11 rounded-xl object-cover" loading="lazy" />
        <div>
          <h2 class="font-serif text-xl font-bold" style="color: var(--text-primary);">花花日记</h2>
          <p class="text-xs mt-0.5" style="color: var(--text-tertiary);">基金投资助手 · PWA + Android</p>
        </div>
      </div>
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" style="color: var(--text-tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </div>
    <div id="huahua-stats-content" class="grid grid-cols-3 sm:grid-cols-6 gap-3">
      <div class="text-center p-3 rounded-xl" style="background: var(--bg-elevated);">
        <div class="text-lg font-bold" style="color: var(--text-tertiary);">--</div>
        <div class="text-[11px] mt-0.5" style="color: var(--text-tertiary);">今日访问</div>
      </div>
      <div class="text-center p-3 rounded-xl" style="background: var(--bg-elevated);">
        <div class="text-lg font-bold" style="color: var(--text-tertiary);">--</div>
        <div class="text-[11px] mt-0.5" style="color: var(--text-tertiary);">今日登录</div>
      </div>
      <div class="text-center p-3 rounded-xl" style="background: var(--bg-elevated);">
        <div class="text-lg font-bold" style="color: var(--text-tertiary);">--</div>
        <div class="text-[11px] mt-0.5" style="color: var(--text-tertiary);">今日访客</div>
      </div>
      <div class="text-center p-3 rounded-xl" style="background: var(--bg-elevated);">
        <div class="text-lg font-bold" style="color: var(--text-tertiary);">--</div>
        <div class="text-[11px] mt-0.5" style="color: var(--text-tertiary);">总用户</div>
      </div>
    </div>
    <div id="huahua-stats-error" class="hidden text-center py-4 text-sm" style="color: var(--text-tertiary);">
      暂无数据
    </div>
  </a>

  <!-- Navigation — asymmetric bento -->
  <section class="grid grid-cols-2 gap-3 mb-14">
    <a href="/notes" class="card card-accent p-5 col-span-2 sm:col-span-1 reveal reveal-delay-2 group">
      <div class="text-2xl mb-3">📝</div>
      <h3 class="font-serif text-lg font-bold mb-1" style="color: var(--text-primary);">笔记</h3>
      <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">来自 Obsidian 的知识沉淀，涵盖 AI、科技、投资、学习</p>
    </a>
    <a href="/repos" class="card card-accent p-5 reveal reveal-delay-3 group">
      <div class="text-2xl mb-3">💻</div>
      <h3 class="font-serif text-lg font-bold mb-1" style="color: var(--text-primary);">项目</h3>
      <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">开源仓库 · 热力图</p>
    </a>
    <a href="/huahua" class="card card-accent p-5 reveal reveal-delay-4 group">
      <div class="text-2xl mb-3">🌸</div>
      <h3 class="font-serif text-lg font-bold mb-1" style="color: var(--text-primary);">花花日记</h3>
      <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">基金投资助手</p>
    </a>
  </section>

  <!-- About — minimal, editorial -->
  <section class="reveal">
    <div class="dot-divider mb-8">关于</div>
    <div class="flex items-start gap-5">
      <img src="/avatar.jpg" alt="白也" class="w-14 h-14 rounded-2xl object-cover flex-shrink-0" style="border: 2px solid var(--border);" loading="lazy" />
      <div class="space-y-2 text-sm leading-relaxed" style="color: var(--text-secondary);">
        <p>
          安装工程造价师，喜欢用 AI 解决生活中的各种问题，热衷尝试各种 AI 应用。
        </p>
        <p>
          做了<a href="/huahua" class="font-medium transition-colors hover:text-[var(--accent)]" style="color: var(--accent);">花花日记</a>来管理基金投资，用 Obsidian 记录生活和学习笔记，偶尔在 <a href="https://github.com/baiye1997" target="_blank" class="font-medium transition-colors hover:text-[var(--accent)]" style="color: var(--accent);">GitHub</a> 上分享一些项目。
        </p>
        <p class="text-xs pt-1" style="color: var(--text-tertiary);">
          小米 · AI · LOL · 杜兰特 · 花花日记开发者 🐱
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(12deg); }
    75% { transform: rotate(-8deg); }
  }
</style>

<script is:inline>
  const HUAHUA_API_URL = 'https://huahua.preview.aliyun-zeabur.cn/api/public/blog-stats';
  const HUAHUA_API_KEY='hf_blo...d5Sa';
  let _huahuaData = null;

  function renderStats(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return;
    const isDark = document.documentElement.classList.contains('dark');
    const bg = isDark ? '#252320' : '#F5F0EB';
    const lc = isDark ? '#A09890' : '#6B6560';
    if (!_huahuaData) return;
    const d = _huahuaData;
    el.innerHTML = [
      [d.today_visit_count, '今日访问', 'var(--accent)'],
      [d.today_logged_in_users, '今日登录', 'var(--sage)'],
      [d.today_visitor_users, '今日访客', 'var(--accent)'],
      [d.total_users, '总用户', 'var(--sage)'],
      [d.total_pro_users, 'Pro 用户', '#D4A03A'],
      [d.total_vip_users, 'VIP 用户', '#D4A03A'],
    ].map(([v, label, color]) =>
      `<div class="text-center p-3 rounded-xl" style="background:${bg}">
        <div class="text-lg font-bold" style="color:${color}">${v ?? '--'}</div>
        <div class="text-[11px] mt-0.5" style="color:${lc}">${label}</div>
      </div>`
    ).join('');
  }

  async function fetchHuahuaStats() {
    if (!HUAHUA_API_URL || !HUAHUA_API_KEY) {
      document.getElementById('huahua-stats-error')?.classList.remove('hidden');
      document.getElementById('huahua-stats-content')?.classList.add('hidden');
      return;
    }
    try {
      const res = await fetch(HUAHUA_API_URL, { headers: { 'Authorization': `Bearer ${HUAHUA_API_KEY}` } });
      if (!res.ok) throw new Error('API failed');
      _huahuaData = await res.json();
      renderStats('huahua-stats-content');
    } catch (e) {
      console.error('Huahua stats error:', e);
      document.getElementById('huahua-stats-error')?.classList.remove('hidden');
      document.getElementById('huahua-stats-content')?.classList.add('hidden');
    }
  }

  fetchHuahuaStats();

  new MutationObserver(() => { if (_huahuaData) renderStats('huahua-stats-content'); })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
