---
import Layout from '../layouts/Layout.astro';

// Fetch GitHub repos count at build time
let repoCount = 0;
try {
  const response = await fetch('https://api.github.com/users/baiye1997/repos?per_page=100');
  const repos = await response.json();
  repoCount = repos.filter((r: any) => !r.private).length;
} catch (e) {
  console.error('Failed to fetch repos:', e);
}

const sections = [
  {
    title: '笔记',
    subtitle: '来自 Obsidian 的知识沉淀',
    icon: '📝',
    href: '/notes',
    color: '#4169E1',
  },
  {
    title: '项目',
    subtitle: 'GitHub 开源仓库 · 贡献热力图',
    icon: '💻',
    href: '/repos',
    color: '#6495ED',
  },
  {
    title: '花花日记',
    subtitle: '基金投资助手 · PWA + Android',
    icon: '🐱',
    href: '/about#huahua',
    color: '#F06292',
  },
];
---

<Layout title="白也 - 个人主页">
  <!-- Hero -->
  <section class="flex items-center gap-4 mb-10">
    <img src="/avatar.jpg" alt="白也" class="w-16 h-16 rounded-2xl object-cover shadow-lg" />
    <div>
      <h1 class="text-[34px] font-bold tracking-tight leading-tight">白也</h1>
      <p class="text-[#8E8E93] text-base mt-0.5">AI 爱好者 · 成都</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-3 mb-10">
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#4169E1]">4</div>
      <div class="text-xs text-[#8E8E93] mt-0.5">笔记</div>
    </div>
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#6495ED]">{repoCount || '—'}</div>
      <div class="text-xs text-[#8E8E93] mt-0.5">项目</div>
    </div>
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#F06292]">
        <span id="busuanzi_value_site_uv">--</span>
      </div>
      <div class="text-xs text-[#8E8E93] mt-0.5">今日访客</div>
    </div>
  </section>

  <!-- 花花日记 Stats -->
  <section id="huahua-stats" class="bg-white rounded-2xl p-6 shadow-sm mb-10">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-2xl">🐱</span>
      <h2 class="text-[22px] font-bold tracking-tight">花花日记</h2>
    </div>
    <div id="huahua-stats-content" class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <!-- Loading placeholder -->
      <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
        <div class="text-xl font-bold text-[#8E8E93]">--</div>
        <div class="text-xs text-[#8E8E93] mt-0.5">今日访问</div>
      </div>
      <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
        <div class="text-xl font-bold text-[#8E8E93]">--</div>
        <div class="text-xs text-[#8E8E93] mt-0.5">活跃用户</div>
      </div>
      <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
        <div class="text-xl font-bold text-[#8E8E93]">--</div>
        <div class="text-xs text-[#8E8E93] mt-0.5">总用户</div>
      </div>
      <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
        <div class="text-xl font-bold text-[#8E8E93]">--</div>
        <div class="text-xs text-[#8E8E93] mt-0.5">Pro 用户</div>
      </div>
    </div>
    <div id="huahua-stats-error" class="hidden text-center py-4 text-sm text-[#8E8E93]">
      暂无数据
    </div>
  </section>

  <!-- Navigation cards -->
  <section class="space-y-3 mb-10">
    {sections.map(section => (
      <a href={section.href} class="bg-white rounded-2xl p-5 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow group">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style={`background-color: ${section.color}15`}>
          {section.icon}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-base">{section.title}</h3>
          <p class="text-sm text-[#8E8E93] mt-0.5">{section.subtitle}</p>
        </div>
        <svg class="w-5 h-5 text-[#C6C6C8] group-hover:text-[#4169E1] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ))}
  </section>

  <!-- About -->
  <section class="bg-white rounded-2xl p-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-3">关于我</h2>
    <div class="space-y-3 text-sm text-[#3C3C43] leading-relaxed">
      <p>
        成都开发者，白天写代码，晚上看基金。养了一只叫花花的猫 🐱
      <p>成都人，喜欢用 AI 解决生活中的各种问题，热衷尝试各种 AI 应用。养了一只叫花花的猫 🐱</p>
      <p>做了<a href="/about#huahua" class="text-[#4169E1] hover:underline">花花日记</a>来管理基金投资，用 Obsidian 记录生活和学习笔记，偶尔在 <a href="https://github.com/baiye1997" target="_blank" class="text-[#4169E1] hover:underline">GitHub</a> 上分享一些项目。</p>
      <div class="flex flex-wrap gap-2 pt-2">
        <span class="px-3 py-1 rounded-full bg-[#4169E1]/10 text-[#4169E1] text-xs font-medium">TypeScript</span>
        <span class="px-3 py-1 rounded-full bg-[#6495ED]/10 text-[#6495ED] text-xs font-medium">React</span>
        <span class="px-3 py-1 rounded-full bg-[#4169E1]/10 text-[#4169E1] text-xs font-medium">Vue</span>
        <span class="px-3 py-1 rounded-full bg-[#6495ED]/10 text-[#6495ED] text-xs font-medium">Python</span>
        <span class="px-3 py-1 rounded-full bg-[#F06292]/10 text-[#F06292] text-xs font-medium">Capacitor</span>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // 花花日记 API 配置
  const HUAHUA_API_URL = 'https://huahua.preview.aliyun-zeabur.cn/api/public/blog-stats';
  const HUAHUA_API_KEY = 'hf_blog_stats_2026_4vF8kQm2Zr7Lp9Nx6Tw3Yc1Hd5Sa';

  async function fetchHuahuaStats() {
    if (!HUAHUA_API_URL || !HUAHUA_API_KEY) {
      // API 未配置，显示默认状态
      document.getElementById('huahua-stats-error').classList.remove('hidden');
      document.getElementById('huahua-stats-content').classList.add('hidden');
      return;
    }

    try {
      const response = await fetch(HUAHUA_API_URL, {
        headers: {
          'X-API-Key': HUAHUA_API_KEY,
        },
      });

      if (!response.ok) throw new Error('API request failed');

      const data = await response.json();

      // 更新统计卡片
      document.getElementById('huahua-stats-content').innerHTML = `
        <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
          <div class="text-xl font-bold text-[#4169E1]">${data.today_visit_count ?? '--'}</div>
          <div class="text-xs text-[#8E8E93] mt-0.5">今日访问</div>
        </div>
        <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
          <div class="text-xl font-bold text-[#6495ED]">${data.today_logged_in_users ?? '--'}</div>
          <div class="text-xs text-[#8E8E93] mt-0.5">活跃用户</div>
        </div>
        <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
          <div class="text-xl font-bold text-[#4169E1]">${data.total_users ?? '--'}</div>
          <div class="text-xs text-[#8E8E93] mt-0.5">总用户</div>
        </div>
        <div class="text-center p-3 rounded-xl bg-[#F2F2F7]">
          <div class="text-xl font-bold text-[#F06292]">${data.total_pro_users ?? '--'}</div>
          <div class="text-xs text-[#8E8E93] mt-0.5">Pro 用户</div>
        </div>
      `;
    } catch (e) {
      console.error('Failed to fetch Huahua stats:', e);
      document.getElementById('huahua-stats-error').classList.remove('hidden');
      document.getElementById('huahua-stats-content').classList.add('hidden');
    }
  }

  fetchHuahuaStats();
</script>
