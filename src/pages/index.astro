---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    title: '笔记',
    subtitle: '来自 Obsidian 的知识沉淀',
    icon: '📝',
    href: '/notes',
    color: '#4169E1',
  },
  {
    title: '项目',
    subtitle: 'GitHub 开源仓库 · 贡献热力图',
    icon: '💻',
    href: '/repos',
    color: '#6495ED',
  },
  {
    title: '花花日记',
    subtitle: '基金投资助手 · PWA + Android',
    icon: '🐱',
    href: '/about#huahua',
    color: '#F06292',
  },
];
---

<Layout title="白也 - 个人主页">
  <!-- Hero -->
  <section class="flex items-center gap-4 mb-10">
    <div class="w-16 h-16 rounded-2xl bg-[#4169E1] flex items-center justify-center text-3xl text-white font-bold shadow-lg">
      B
    </div>
    <div>
      <h1 class="text-[34px] font-bold tracking-tight leading-tight">白也</h1>
      <p class="text-[#8E8E93] text-base mt-0.5">开发者 · 投资者 · 成都</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-3 mb-10">
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#4169E1]">4</div>
      <div class="text-xs text-[#8E8E93] mt-0.5">笔记</div>
    </div>
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#6495ED]">—</div>
      <div class="text-xs text-[#8E8E93] mt-0.5">项目</div>
    </div>
    <div class="bg-white rounded-2xl p-4 text-center shadow-sm">
      <div class="text-2xl font-bold text-[#F06292]">
        <span id="busuanzi_value_site_uv">--</span>
      </div>
      <div class="text-xs text-[#8E8E93] mt-0.5">今日访客</div>
    </div>
  </section>

  <!-- Navigation cards -->
  <section class="space-y-3 mb-10">
    {sections.map(section => (
      <a href={section.href} class="bg-white rounded-2xl p-5 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow group">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style={`background-color: ${section.color}15`}>
          {section.icon}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-base">{section.title}</h3>
          <p class="text-sm text-[#8E8E93] mt-0.5">{section.subtitle}</p>
        </div>
        <svg class="w-5 h-5 text-[#C6C6C8] group-hover:text-[#4169E1] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ))}
  </section>

  <!-- About -->
  <section class="bg-white rounded-2xl p-6 shadow-sm">
    <h2 class="text-[22px] font-bold tracking-tight mb-3">关于我</h2>
    <div class="space-y-3 text-sm text-[#3C3C43] leading-relaxed">
      <p>
        成都开发者，白天写代码，晚上看基金。养了一只叫花花的猫 🐱
      </p>
      <p>
        做了<a href="/about#huahua" class="text-[#4169E1] hover:underline">花花日记</a>来管理基金投资，
        用 Obsidian 记录生活和技术笔记，
        偶尔在 <a href="https://github.com/baiye1997" target="_blank" class="text-[#4169E1] hover:underline">GitHub</a> 上搞点开源。
      </p>
      <div class="flex flex-wrap gap-2 pt-2">
        <span class="px-3 py-1 rounded-full bg-[#4169E1]/10 text-[#4169E1] text-xs font-medium">TypeScript</span>
        <span class="px-3 py-1 rounded-full bg-[#6495ED]/10 text-[#6495ED] text-xs font-medium">React</span>
        <span class="px-3 py-1 rounded-full bg-[#4169E1]/10 text-[#4169E1] text-xs font-medium">Vue</span>
        <span class="px-3 py-1 rounded-full bg-[#6495ED]/10 text-[#6495ED] text-xs font-medium">Python</span>
        <span class="px-3 py-1 rounded-full bg-[#F06292]/10 text-[#F06292] text-xs font-medium">Capacitor</span>
      </div>
    </div>
  </section>
</Layout>
